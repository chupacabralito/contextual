{
  "name": "@contextual/demo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "npm run build --workspace=@contextual/shared && npm run build --workspace=@contextual/react",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "pretypecheck": "npm run build --workspace=@contextual/shared && npm run build --workspace=@contextual/react",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@contextual/react": "*",
    "@contextual/shared": "*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
