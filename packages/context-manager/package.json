{
  "name": "@contextualapp/context-manager",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "npm run build --workspace=@contextualapp/shared && npm run build --workspace=@contextualapp/react",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "pretypecheck": "npm run build --workspace=@contextualapp/shared && npm run build --workspace=@contextualapp/react",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@contextualapp/react": "*",
    "@contextualapp/shared": "*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  }
}
