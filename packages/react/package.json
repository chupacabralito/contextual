{
  "name": "@contextual/react",
  "version": "0.1.0",
  "description": "React annotation component for AI-assisted design iteration with organizational context",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "prebuild": "npm run build --workspace=@contextual/shared",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npm run build && node --test test/**/*.test.mjs",
    "pretypecheck": "npm run build --workspace=@contextual/shared",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@contextual/shared": "^0.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "annotation",
    "ai",
    "design",
    "context",
    "agent",
    "contextual"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chupacabralito/contextual.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/chupacabralito/contextual#readme",
  "bugs": {
    "url": "https://github.com/chupacabralito/contextual/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
