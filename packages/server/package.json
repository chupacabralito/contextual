{
  "name": "@contextual/server",
  "version": "0.0.1",
  "description": "Local context server for Contextual - indexes and resolves organizational context",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "contextual-server": "./dist/cli.js"
  },
  "scripts": {
    "prebuild": "npm run build --workspace=@contextual/shared && npm run build --workspace=@contextual/context-manager",
    "build": "tsc",
    "postbuild": "node ../../scripts/copy-context-manager-dist.mjs",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "npm run build && node --test test/**/*.test.mjs",
    "pretypecheck": "npm run build --workspace=@contextual/shared",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@contextual/shared": "*",
    "sql.js": "^1.11.0",
    "chokidar": "^4.0.0",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
