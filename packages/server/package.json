{
  "name": "@contextualapp/server",
  "version": "0.2.0",
  "description": "Local context server for Contextual - indexes and resolves organizational context",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "contextual-server": "./dist/cli.js"
  },
  "scripts": {
    "prebuild": "npm run build --workspace=@contextualapp/shared && npm run build --workspace=@contextualapp/context-manager",
    "build": "tsc",
    "postbuild": "node ../../scripts/copy-context-manager-dist.mjs",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "npm run build && node --test --test-concurrency=1 test/**/*.test.mjs",
    "pretypecheck": "npm run build --workspace=@contextualapp/shared",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@contextualapp/shared": "^0.2.0",
    "sql.js": "^1.11.0",
    "chokidar": "^4.0.0",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chupacabralito/contextual.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/chupacabralito/contextual#readme",
  "bugs": {
    "url": "https://github.com/chupacabralito/contextual/issues"
  },
  "keywords": [
    "contextual",
    "context",
    "ai",
    "agent",
    "server",
    "cli"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
