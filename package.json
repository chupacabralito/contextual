{
  "name": "contextual",
  "private": true,
  "version": "0.0.0",
  "description": "Local-first context and pass memory for repo-native agents",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "npm run build --workspaces",
    "build:server": "npm run build --workspace=@contextualapp/server",
    "dev:server": "npm run dev --workspace=@contextualapp/server",
    "dev:context-manager": "npm run dev --workspace=@contextualapp/context-manager",
    "dev:react": "npm run dev --workspace=@contextualapp/react",
    "contextual:init": "node packages/server/dist/cli.js init",
    "contextual:scaffold": "node packages/server/dist/cli.js scaffold",
    "contextual:serve": "node packages/server/dist/cli.js serve",
    "contextual:start": "node packages/server/dist/cli.js start",
    "contextual:pair": "node packages/server/dist/cli.js pair",
    "contextual:pair-status": "node packages/server/dist/cli.js pair-status",
    "contextual:record-outcome": "node packages/server/dist/cli.js record-outcome",
    "test:server": "npm test --workspace=@contextualapp/server",
    "test:react": "npm test --workspace=@contextualapp/react",
    "test": "npm run test:server && npm run test:react",
    "typecheck": "npm run typecheck --workspaces",
    "clean": "npm run clean --workspaces"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
